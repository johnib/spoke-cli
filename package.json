{
  "name": "@spoke-phone/cli",
  "version": "0.1.0",
  "description": "Command-line interface for Spoke Phone",
  "bin": {
    "spoke": "./bin/spoke"
  },
  "main": "dist/index.js",
  "files": [
    "bin",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "spoke",
    "spoke-phone",
    "cli",
    "voip",
    "telephony",
    "mcp"
  ],
  "author": "Spoke Phone",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^5.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.0",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "jsonata": "^2.0.5",
    "localtunnel": "^2.0.2",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/localtunnel": "^2.0.4",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nock": "^13.5.4",
    "prettier": "^3.3.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
