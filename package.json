{
  "name": "@johnib/spoke-cli",
  "version": "0.1.0",
  "description": "Third-party command-line interface for Spoke Phone, plus an MCP bridge for AI agents",
  "bin": {
    "spoke": "./bin/spoke"
  },
  "main": "dist/index.js",
  "files": [
    "bin",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "spoke",
    "spoke-phone",
    "cli",
    "voip",
    "telephony",
    "mcp",
    "oauth2",
    "twilio"
  ],
  "author": "Jonathan Barazany <jry157@gmail.com> (https://github.com/johnib)",
  "license": "MIT",
  "homepage": "https://github.com/johnib/spoke-cli#readme",
  "bugs": {
    "url": "https://github.com/johnib/spoke-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnib/spoke-cli.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^5.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.0",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "jsonata": "^2.0.5",
    "localtunnel": "^2.0.2",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "@semantic-release/npm": "^12.0.0",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@types/jest": "^29.5.12",
    "@types/localtunnel": "^2.0.4",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nock": "^13.5.4",
    "prettier": "^3.3.0",
    "semantic-release": "^24.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
